# Environment variables to set in the Vercel project (Settings → Environment Variables).
# Set them for "Production", "Preview" and "Development" as needed.

# ---- Site (used in absolute URLs / SEO / emails) ----
NEXT_PUBLIC_SITE_URL=https://www.levelupingermany.com

# ---- Database (Neon Postgres) ----
# Get this from https://console.neon.tech → your project → Connection Details
# IMPORTANT: use the *pooled* connection string (with `-pooler` in the host).
DATABASE_URL=postgresql://<user>:<password>@<host>-pooler.eu-central-1.aws.neon.tech/<dbname>?sslmode=require

# ---- Vercel Blob (admin image uploads) ----
# Auto-injected when you add a Blob store from the Vercel dashboard
# (Storage → Create → Blob → Connect to project). DO NOT set manually.
BLOB_READ_WRITE_TOKEN=

# ---- Resend (transactional email) ----
RESEND_API_KEY=
FORMS_TO_EMAIL=info@levelupingermany.com
FORMS_FROM_EMAIL=Level Up in Germany <info@levelupingermany.com>
NEWSLETTER_FROM_EMAIL=Level Up in Germany <info@levelupingermany.com>

# ---- Cloudflare Turnstile (captcha) ----
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ---- WhatsApp join link ----
NEXT_PUBLIC_WHATSAPP_JOIN_URL=

# ---- SEO (optional) ----
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
