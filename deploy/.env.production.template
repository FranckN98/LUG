# Copy this file to /var/www/levelupingermany/current/.env on the server.
# Replace every placeholder marked <...> with the real value.
# DO NOT commit this filled file to git.

# ---- Site ----
NEXT_PUBLIC_SITE_URL=https://www.levelupingermany.de
NODE_ENV=production
PORT=3000

# ---- Database (SQLite, persisted outside the deploy folder) ----
# Make sure the directory exists and is owned by the deploy user:
#   sudo mkdir -p /var/lib/levelupingermany
#   sudo chown -R deploy:deploy /var/lib/levelupingermany
DATABASE_URL="file:/var/lib/levelupingermany/prod.db"

# ---- SEO (optional) ----
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=<google-site-verification-token>

# ---- Resend (transactional email) ----
RESEND_API_KEY=<your-resend-api-key>
FORMS_TO_EMAIL=info@levelupingermany.de
FORMS_FROM_EMAIL=Level Up in Germany <info@levelupingermany.de>
NEWSLETTER_FROM_EMAIL=Level Up in Germany <info@levelupingermany.de>

# ---- Cloudflare Turnstile (captcha) ----
NEXT_PUBLIC_TURNSTILE_SITE_KEY=<turnstile-site-key>
TURNSTILE_SECRET_KEY=<turnstile-secret-key>

# ---- WhatsApp join link ----
NEXT_PUBLIC_WHATSAPP_JOIN_URL=<https://chat.whatsapp.com/...>
